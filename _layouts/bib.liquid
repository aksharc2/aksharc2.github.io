---
---
<div class="row">
  <div id="{{ entry.key }}" class="col-sm-12">

    <div class="author">
      {% assign author_array_size = entry.author_array | size %}
      {% assign author_array_limit = author_array_size %}
      {% if site.max_author_limit and author_array_size > site.max_author_limit %}
        {% assign author_array_limit = site.max_author_limit %}
      {% endif %}

      {%- for author in entry.author_array limit: author_array_limit -%}
        {%- assign is_self = false -%}
        {%- assign clean_last = author.last | remove: '¶' | remove: '&' | remove: '*' | remove: '†' | remove: '^' | strip -%}
        {%- assign clean_first = author.first | strip -%}

        {%- if clean_last == "Chavan" and clean_first contains "Akshar" -%}
          {%- assign is_self = true -%}
        {%- endif -%}

        {%- assign first_parts = clean_first | split: ' ' -%}
        {%- capture initials -%}
          {%- for part in first_parts -%}
            {%- assign trimmed = part | strip -%}
            {%- if trimmed != "" -%}
              {{ trimmed | slice: 0 }}.{% unless forloop.last %} {% endunless %}
            {%- endif -%}
          {%- endfor -%}
        {%- endcapture -%}

        {%- if forloop.length > 1 -%}
          {% if forloop.first == false %}, {% endif %}
          {%- if forloop.last and author_array_limit == author_array_size %}and {% endif -%}
        {% endif %}

        {%- if is_self -%}
          <strong>{{ initials | strip }} {{ clean_last }}</strong>
        {%- else -%}
          {{ initials | strip }} {{ clean_last }}
        {%- endif -%}
      {% endfor %}

      {%- assign more_authors = author_array_size | minus: author_array_limit -%}
      {% if more_authors > 0 %}, et al.{% endif %}
    </div>

    <div class="title">
      “{{ entry.title }},”
    </div>

    <div class="periodical">
      {% assign proceedings = 'inproceedings,incollection' | split: ',' %}
      {% assign thesis = 'thesis,mastersthesis,phdthesis' | split: ',' %}

      {% if entry.type == 'article' %}
        <em>{{ entry.journal }}</em>
      {% elsif proceedings contains entry.type %}
        <em>{{ entry.booktitle }}</em>
      {% elsif thesis contains entry.type %}
        <em>{{ entry.school }}</em>
      {% elsif entry.booktitle %}
        <em>{{ entry.booktitle }}</em>
      {% elsif entry.journal %}
        <em>{{ entry.journal }}</em>
      {% endif %}

      {% if entry.volume %}, vol. {{ entry.volume }}{% endif %}
      {% if entry.number %}, no. {{ entry.number }}{% endif %}
      {% if entry.pages %}, pp. {{ entry.pages }}{% endif %}
      {% if entry.location %}, {{ entry.location }}{% endif %}.
    </div>

    <span style="margin-left: 0.35rem;">
      {% if entry.pdf %}
        {% if entry.pdf contains '://' %}
          <a href="{{ entry.pdf }}" target="_blank">[PDF]</a>
        {% else %}
          <a href="{{ entry.pdf | prepend: '/assets/pdf/' | relative_url }}" target="_blank">[PDF]</a>
        {% endif %}
      {% elsif entry.doi %}
        <a href="https://doi.org/{{ entry.doi }}" target="_blank">[DOI]</a>
      {% elsif entry.url %}
        <a href="{{ entry.url }}" target="_blank">[Link]</a>
      {% endif %}
    </span>

  </div>
</div>